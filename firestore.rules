rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read access to users collection (for bot and admin)
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Allow read/write for authenticated admin users
    match /clients/{clientId} {
      allow read, write: if request.auth != null;
    }

    // Allow read access to config (for bot to fetch categories)
    match /config/{configId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Allow read access to documents (for bot)
    match /documents/{documentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Allow read/write to sessions (for bot state management)
    match /sessions/{sessionId} {
      allow read, write: if true;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
